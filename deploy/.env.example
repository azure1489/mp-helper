# 复制为 deploy/.env 并填入真实值（deploy/.env 已被 .gitignore 忽略，不会进仓库）
SSH_HOST=8.138.43.109
SSH_PORT=22
SSH_USER=root

DOMAIN=mp-helper.aworld.ltd
REMOTE_DIR=/opt/mp-helper

# mp-server 监听地址：172.17.0.1 = docker0 网关，仅宿主/容器可达，不暴露公网
BIND_ADDR=172.17.0.1:8088

# 应用 admin token（/admin/* 接口）
ADMIN_TOKEN=replace-with-a-strong-token

# 宿主上的 nginx（docker）
NGINX_CONTAINER=base-nginx
NGINX_CONFD=/opt/docker/nginx/conf.d
